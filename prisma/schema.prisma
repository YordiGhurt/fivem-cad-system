generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SUPERVISOR
  OFFICER
  DISPATCHER
  USER
}

enum OrgType {
  POLICE
  FIRE
  AMBULANCE
  DOJ
  CUSTOM
}

enum UnitStatus {
  AVAILABLE
  BUSY
  OFFDUTY
  ONSCENE
  ENROUTE
  BREAK
}

enum IncidentStatus {
  ACTIVE
  PENDING
  CLOSED
  CANCELLED
}

enum ReportType {
  INCIDENT
  ARREST
  WARRANT
  MEDICAL
  CUSTOM
}

enum WarrantStatus {
  ACTIVE
  EXPIRED
  SERVED
}

enum LawCategory {
  CRIMINAL
  CIVIL
  TRAFFIC
  ADMINISTRATIVE
}

enum VerdictType {
  GUILTY
  NOT_GUILTY
  PLEA_DEAL
  DISMISSED
}

enum ChargeStatus {
  PENDING
  ACTIVE
  DISMISSED
  SERVED
}

enum DeathCause {
  NATURAL
  ACCIDENT
  HOMICIDE
  SUICIDE
  UNKNOWN
}

enum AdminLogAction {
  USER_CREATED
  USER_UPDATED
  USER_BANNED
  ORG_CREATED
  ORG_UPDATED
  PERMISSION_CHANGED
  RANK_CREATED
  RANK_UPDATED
  DATA_DELETED
  SYSTEM_CONFIG
}

enum CaseFileStatus {
  OPEN
  UNDER_REVIEW
  CLOSED
  ARCHIVED
}

enum WarningSeverity {
  MINOR
  MAJOR
  FINAL
}

enum TrainingType {
  BASIC
  ADVANCED
  SPECIALIST
  REFRESHER
  SUPERVISOR
  CUSTOM
}

model User {
  id                 String             @id @default(cuid())
  username           String             @unique
  email              String             @unique
  password           String
  citizenId          String?
  steamId            String?
  role               Role               @default(USER)
  active             Boolean            @default(true)
  organizationId     String?
  organization       Organization?      @relation(fields: [organizationId], references: [id])
  rankId             String?
  rank               OrgRank?           @relation(fields: [rankId], references: [id])
  units                Unit[]
  reports              Report[]
  incidentNotes        IncidentNote[]
  warrants             Warrant[]
  lawsCreated          Law[]              @relation("LawCreatedBy")
  verdictJudge         Verdict[]          @relation("VerdictJudge")
  chargesIssued        Charge[]           @relation("ChargeIssuedBy")
  caseFilesAssigned    CaseFile[]         @relation("CaseFileAssignedTo")
  caseFilesCreated     CaseFile[]         @relation("CaseFileCreatedBy")
  caseDocuments        CaseDocument[]     @relation("CaseDocumentAuthor")
  deathCertificates    DeathCertificate[] @relation("DeathCertDoctor")
  adminLogs            AdminLog[]         @relation("AdminLogPerformedBy")
  medicalRecords       MedicalRecord[]    @relation("MedicalRecordAuthor")
  orgNewsAuthored      OrgNews[]          @relation("OrgNewsAuthor")
  orgWarningsReceived  OrgWarning[]       @relation("OrgWarningTarget")
  orgWarningsIssued    OrgWarning[]       @relation("OrgWarningIssuedBy")
  trainingAsTrainee    TrainingRecord[]   @relation("TrainingRecordTrainee")
  trainingAsTrainer    TrainingRecord[]   @relation("TrainingRecordTrainer")
  dispatchLogs         DispatchLog[]      @relation("DispatchLogDispatcher")
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model Organization {
  id                String             @id @default(cuid())
  name              String             @unique
  type              OrgType
  callsign          String
  color             String             @default("#3b82f6")
  description       String?
  active            Boolean            @default(true)
  users             User[]
  units             Unit[]
  incidents         Incident[]
  permissions       OrgPermission?
  ranks             OrgRank[]
  deathCertificates DeathCertificate[]
  medicalRecords    MedicalRecord[]
  news              OrgNews[]
  warnings          OrgWarning[]
  trainingRecords   TrainingRecord[]
  dispatchLogs      DispatchLog[]
  createdAt         DateTime           @default(now())
}

model OrgPermission {
  id                      String       @id @default(cuid())
  organizationId          String       @unique
  organization            Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  canViewIncidents        Boolean      @default(true)
  canCreateIncidents      Boolean      @default(false)
  canViewWarrants         Boolean      @default(false)
  canCreateWarrants       Boolean      @default(false)
  canViewReports          Boolean      @default(true)
  canCreateReports        Boolean      @default(false)
  canViewCitizens         Boolean      @default(false)
  canViewVehicles         Boolean      @default(false)
  canManageUnits          Boolean      @default(false)
  canViewLaws             Boolean      @default(false)
  canCreateLaws           Boolean      @default(false)
  canViewVerdicts         Boolean      @default(false)
  canCreateVerdicts       Boolean      @default(false)
  canViewCharges          Boolean      @default(false)
  canCreateCharges        Boolean      @default(false)
  canViewCaseFiles        Boolean      @default(false)
  canCreateCaseFiles      Boolean      @default(false)
  canViewDeathCerts       Boolean      @default(false)
  canCreateDeathCerts     Boolean      @default(false)
  canViewMedicalRecords   Boolean      @default(false)
  canCreateMedicalRecords Boolean      @default(false)
  canViewAdminLog         Boolean      @default(false)
  canViewNews             Boolean      @default(true)
  canCreateNews           Boolean      @default(false)
  canViewWarnings         Boolean      @default(false)
  canCreateWarnings       Boolean      @default(false)
  canViewTrainingRecords  Boolean      @default(false)
  canCreateTrainingRecords Boolean     @default(false)
  canViewDispatchLog      Boolean      @default(false)
  canCreateDispatchLog    Boolean      @default(false)
  canDeleteIncidents      Boolean      @default(false)
  canDeleteWarrants       Boolean      @default(false)
  canDeleteReports        Boolean      @default(false)
  canDeleteCitizens       Boolean      @default(false)
  canDeleteLaws           Boolean      @default(false)
  canDeleteVerdicts       Boolean      @default(false)
  canDeleteCharges        Boolean      @default(false)
  canDeleteCaseFiles      Boolean      @default(false)
  canDeleteDeathCerts     Boolean      @default(false)
  canDeleteMedicalRecords Boolean      @default(false)
  canDeleteNews           Boolean      @default(false)
  canDeleteWarnings       Boolean      @default(false)
  canDeleteTrainingRecords Boolean     @default(false)
  canDeleteDispatchLog    Boolean      @default(false)
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
}

model OrgRank {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  level          Int
  color          String       @default("#94a3b8")
  permissions    Json?
  users          User[]
  createdAt      DateTime     @default(now())

  @@unique([organizationId, name])
  @@unique([organizationId, level])
}

model Unit {
  id             String       @id @default(cuid())
  callsign       String
  status         UnitStatus   @default(OFFDUTY)
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  position       Json?
  activeCallId   String?
  incidentUnits  IncidentUnit[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Incident {
  id             String         @id @default(cuid())
  caseNumber     String         @unique
  type           String
  description    String
  location       String
  coordinates    Json?
  status         IncidentStatus @default(PENDING)
  priority       Int            @default(3)
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  units          IncidentUnit[]
  reports        Report[]
  notes          IncidentNote[]
  createdById    String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  closedAt       DateTime?
}

model IncidentUnit {
  id         String   @id @default(cuid())
  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id])
  unitId     String
  unit       Unit     @relation(fields: [unitId], references: [id])
  assignedAt DateTime @default(now())

  @@unique([incidentId, unitId])
}

model IncidentNote {
  id         String   @id @default(cuid())
  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id])
  content    String
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  createdAt  DateTime @default(now())
}

model Report {
  id         String     @id @default(cuid())
  title      String
  content    String     @db.Text
  incidentId String?
  incident   Incident?  @relation(fields: [incidentId], references: [id])
  type       ReportType @default(INCIDENT)
  authorId   String
  author     User       @relation(fields: [authorId], references: [id])
  pdfUrl     String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Citizen {
  id                String             @id @default(cuid())
  firstName         String
  lastName          String
  dateOfBirth       DateTime?
  citizenId         String             @unique
  gender            String?
  phone             String?
  address           String?
  nationality       String?
  image             String?
  notes             String?            @db.Text
  vehicles          Vehicle[]
  weapons           Weapon[]
  verdicts          Verdict[]
  charges           Charge[]
  caseFiles         CaseFile[]
  deathCertificates DeathCertificate[]
  medicalRecords    MedicalRecord[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model Vehicle {
  id                 String    @id @default(cuid())
  plate              String    @unique
  model              String
  color              String
  ownerId            String
  owner              Citizen   @relation(fields: [ownerId], references: [citizenId])
  stolen             Boolean   @default(false)
  flagged            Boolean   @default(false)
  flagReason         String?
  registrationExpiry DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model Warrant {
  id          String        @id @default(cuid())
  citizenName String
  citizenId   String?
  reason      String
  charges     String        @db.Text
  status      WarrantStatus @default(ACTIVE)
  issuedById  String
  issuedBy    User          @relation(fields: [issuedById], references: [id])
  expiresAt   DateTime?
  pdfUrl      String?
  createdAt   DateTime      @default(now())
}

model Weapon {
  id           String   @id @default(cuid())
  serialNumber String   @unique
  model        String
  ownerId      String
  owner        Citizen  @relation(fields: [ownerId], references: [citizenId])
  licensed     Boolean  @default(false)
  flagged      Boolean  @default(false)
  flagReason   String?
  createdAt    DateTime @default(now())
}

// DOJ – Gesetze
model Law {
  id          String      @id @default(cuid())
  code        String      @unique
  title       String
  description String      @db.Text
  category    LawCategory
  penalty     String?
  fineAmount  Float?
  jailTime    Int?
  active      Boolean     @default(true)
  createdById String
  createdBy   User        @relation("LawCreatedBy", fields: [createdById], references: [id])
  charges     Charge[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// DOJ – Urteile
model Verdict {
  id          String      @id @default(cuid())
  caseNumber  String      @unique
  citizenName String
  citizenId   String?
  citizen     Citizen?    @relation(fields: [citizenId], references: [citizenId])
  type        VerdictType
  sentence    String?     @db.Text
  jailTime    Int?
  fineAmount  Float?
  judgeId     String
  judge       User        @relation("VerdictJudge", fields: [judgeId], references: [id])
  caseFileId  String?
  caseFile    CaseFile?   @relation(fields: [caseFileId], references: [id])
  charges     Charge[]
  notes       String?     @db.Text
  pdfUrl      String?
  issuedAt    DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// LSPD/DOJ – Anklagen
model Charge {
  id          String       @id @default(cuid())
  citizenName String
  citizenId   String?
  citizen     Citizen?     @relation(fields: [citizenId], references: [citizenId])
  lawId       String?
  law         Law?         @relation(fields: [lawId], references: [id])
  description String       @db.Text
  status      ChargeStatus @default(PENDING)
  issuedById  String
  issuedBy    User         @relation("ChargeIssuedBy", fields: [issuedById], references: [id])
  verdictId   String?
  verdict     Verdict?     @relation(fields: [verdictId], references: [id])
  caseFileId  String?
  caseFile    CaseFile?    @relation(fields: [caseFileId], references: [id])
  incidentId  String?
  pdfUrl      String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

// DOJ/LSPD – Parteiakten
model CaseFile {
  id           String         @id @default(cuid())
  caseNumber   String         @unique
  title        String
  description  String         @db.Text
  status       CaseFileStatus @default(OPEN)
  citizenName  String?
  citizenId    String?
  citizen      Citizen?       @relation(fields: [citizenId], references: [citizenId])
  assignedToId String?
  assignedTo   User?          @relation("CaseFileAssignedTo", fields: [assignedToId], references: [id])
  createdById  String
  createdBy    User           @relation("CaseFileCreatedBy", fields: [createdById], references: [id])
  charges      Charge[]
  verdicts     Verdict[]
  documents    CaseDocument[]
  pdfUrl       String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  closedAt     DateTime?
}

// Dokumente zu Parteiakten
model CaseDocument {
  id         String   @id @default(cuid())
  caseFileId String
  caseFile   CaseFile @relation(fields: [caseFileId], references: [id], onDelete: Cascade)
  title      String
  content    String   @db.Text
  fileUrl    String?
  authorId   String
  author     User     @relation("CaseDocumentAuthor", fields: [authorId], references: [id])
  createdAt  DateTime @default(now())
}

// Ambulanz – Totenscheine
model DeathCertificate {
  id                String       @id @default(cuid())
  certificateNumber String       @unique
  deceasedName      String
  citizenId         String?
  citizen           Citizen?     @relation(fields: [citizenId], references: [citizenId])
  dateOfDeath       DateTime
  timeOfDeath       DateTime?
  locationOfDeath   String
  cause             DeathCause
  causeDescription  String       @db.Text
  doctorId          String
  doctor            User         @relation("DeathCertDoctor", fields: [doctorId], references: [id])
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id])
  additionalNotes   String?      @db.Text
  pdfUrl            String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

// Admin-Log
model AdminLog {
  id            String         @id @default(cuid())
  action        AdminLogAction
  description   String
  targetId      String?
  targetType    String?
  performedById String
  performedBy   User           @relation("AdminLogPerformedBy", fields: [performedById], references: [id])
  metadata      Json?
  createdAt     DateTime       @default(now())
}

// Medizinische Akte (Ambulanz)
model MedicalRecord {
  id             String       @id @default(cuid())
  recordNumber   String       @unique
  citizenName    String
  citizenId      String?
  citizen        Citizen?     @relation(fields: [citizenId], references: [citizenId])
  diagnosis      String       @db.Text
  treatment      String?      @db.Text
  medications    String?      @db.Text
  bloodType      String?
  allergies      String?      @db.Text
  authorId       String
  author         User         @relation("MedicalRecordAuthor", fields: [authorId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  incidentId     String?
  confidential   Boolean      @default(true)
  pdfUrl         String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// Bußgeldkatalog
model FineEntry {
  id             String   @id @default(cuid())
  offense        String
  category       String
  legalSection   String
  fineMin        Int      @default(0)
  fineMax        Int      @default(0)
  jailMin        Int      @default(0)
  jailMax        Int      @default(0)
  seizure        String?
  additionalInfo String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Org-interne News/Ankündigungen
model OrgNews {
  id             String       @id @default(cuid())
  title          String
  content        String       @db.Text
  pinned         Boolean      @default(false)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  authorId       String
  author         User         @relation("OrgNewsAuthor", fields: [authorId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// Disziplinarakte / Abmahnungen
model OrgWarning {
  id             String          @id @default(cuid())
  title          String
  description    String          @db.Text
  severity       WarningSeverity @default(MINOR)
  targetUserId   String
  targetUser     User            @relation("OrgWarningTarget", fields: [targetUserId], references: [id])
  issuedById     String
  issuedBy       User            @relation("OrgWarningIssuedBy", fields: [issuedById], references: [id])
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  resolved       Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

// Ausbildungsakte
model TrainingRecord {
  id             String       @id @default(cuid())
  recordNumber   String       @unique
  traineeName    String
  traineeId      String?
  trainee        User?        @relation("TrainingRecordTrainee", fields: [traineeId], references: [id])
  trainerName    String
  trainerId      String?
  trainer        User?        @relation("TrainingRecordTrainer", fields: [trainerId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           TrainingType
  modules        Json?
  notes          String?      @db.Text
  passed         Boolean      @default(false)
  date           DateTime     @default(now())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// Leitstellennachweis / Schichtbuch
model DispatchLog {
  id             String       @id @default(cuid())
  logNumber      String       @unique
  dispatcherId   String
  dispatcher     User         @relation("DispatchLogDispatcher", fields: [dispatcherId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  shiftStart     DateTime
  shiftEnd       DateTime?
  callsHandled   Int          @default(0)
  notes          String?      @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}
