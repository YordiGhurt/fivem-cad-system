# Datenbank
POSTGRES_USER=cad_user
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
POSTGRES_DB=cad_db
# WICHTIG: DATABASE_URL muss mit POSTGRES_USER, POSTGRES_PASSWORD und POSTGRES_DB übereinstimmen!
DATABASE_URL="postgresql://cad_user:CHANGE_THIS_STRONG_PASSWORD@postgres:5432/cad_db"

# NextAuth – WICHTIG: NEXTAUTH_SECRET muss ein zufälliger langer String sein
# Generieren mit: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_THIS_TO_A_RANDOM_SECRET"
NEXTAUTH_URL="https://cad.bigone1.net"
NEXT_PUBLIC_BASE_URL="https://cad.bigone1.net"

# CAD API-Key für FiveM-Bridge (frei wählbar, aber sicher!)
CAD_API_KEY="CHANGE_THIS_API_KEY"
