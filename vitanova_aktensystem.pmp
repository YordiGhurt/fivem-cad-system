  <CustomScript ScriptType="Server" ScriptCodeType="Table" ScriptName="Row_Inserting" ScriptL1Key="Allgemein_Bußgeldkatalog"><![CDATA[// Row Inserting event
function Row_Inserting($rsold, &$rsnew) {
	// Enter your code here
	// To cancel, set return value to FALSE
	$currentDate = date("d.m.Y H:i:s");
	$newnotiz = "Vorstrafenregister von " . CurrentUserName() . " am " . $currentDate . " erstellt.<hr />";
	$rsnew["Notiz"] = $newnotiz;
	return TRUE;
}

]]></CustomScript>
