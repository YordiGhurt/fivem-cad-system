	return TRUE;

}
]]></CustomScript>
  <CustomScript ScriptType="Server" ScriptCodeType="Table" ScriptName="Row_Updating" ScriptL1Key="LSPD_Strafakten"><![CDATA[// Row Updating event
function Row_Updating($rsold, &$rsnew) {
	$currentDate = date("d-m-y H:i:s");
	$alterstatus = $rsold["Status"];
	$neuerstatus = $rsnew["Status"];
	$oldnotiz = $rsold["Notiz"];
	$newnotiz = "Strafakte geändert von " . CurrentUserName() . " am " . $currentDate . "<br> Alter Status: " . $alterstatus . " / Neuer Status: " . $neuerstatus ."<hr />";
	$testnotiz = $oldnotiz . $newnotiz;
	$rsnew["Notiz"] = $testnotiz;
	return TRUE;
}
]]></CustomScript>
