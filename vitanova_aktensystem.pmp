  <CustomScript ScriptType="Template" ScriptCodeType="Table" ScriptName="CustomTemplate" ScriptCtrlID="view" ScriptL1Key="LSPD_News"><![CDATA[<?php
// Werte auslesen
$id = $Page->id->CurrentValue ?? "";
$date = $Page->Datum->CurrentValue ?? "";
$author = $Page->Ersteller->CurrentValue ?? "";
$content = $Page->News->CurrentValue ?? ""; // HTML-Feld → NICHT escapen!

// Datum schöner formatieren
if (!empty($date)) {
    try {
        $d = \DateTime::createFromFormat('Y-m-d', $date) ?: \DateTime::createFromFormat('d.m.Y', $date);
        $date = $d ? $d->format('d.m.Y') : $date;
    } catch (Exception $e) {}
}
?>

