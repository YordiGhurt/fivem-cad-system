  <CustomScript ScriptType="Server" ScriptCodeType="Table" ScriptName="Row_Rendered" ScriptL1Key="EMFD_News"><![CDATA[// Row Rendered event
function Row_Rendered()
{
if (!EmptyValue($this->News->CurrentValue)) {

    // Datum umformatieren (mm/dd/yy → dd.mm.yyyy)
    $formattedDate = $this->Datum->CurrentValue;
    if (!EmptyValue($formattedDate)) {
        $d = \DateTime::createFromFormat('m/d/y', $formattedDate) ?: \DateTime::createFromFormat('m/d/Y', $formattedDate);
        if ($d) $formattedDate = $d->format('d.m.Y');
    }

    $output  = '<div class="news-card p-3 mb-3">';
    $output .= '<div class="d-flex justify-content-between align-items-center mb-2">';
    $output .= '<h5 class="mb-0 text-light"><i class="fa fa-newspaper me-2 text-info"></i>News</h5>';
    $output .= '<small class="text-muted">' . htmlentities($formattedDate) . '</small>';
    $output .= '</div>';
    $output .= '<div class="mb-2 text-light">' . $this->News->CurrentValue . '</div>';
    $output .= '<div class="text-end"><small class="text-muted">Erstellt von: ' . htmlentities($this->Ersteller->CurrentValue) . '</small></div>';
    $output .= '</div>';

    $this->News->ViewValue = $output;
}

}]]></CustomScript>
  <CustomScript ScriptType="Server" ScriptCodeType="Global" ScriptName="Page_Head"><![CDATA[<script>
ew.USE_OVERLAY_SCROLLBARS = false;
loadjs.ready("makerjs", function () {

  function attachSidebarCopyHandler() {
    // Suche nach dem PDF-Icon in der Sidebar oder Toolbar
    const pdfButtons = document.querySelectorAll(
      "a[data-export='pdf'], button[data-export='pdf'], a[href*='export=pdf'], .ew-export-option a, .ew-sidebar a[href*='export=pdf']"
    );

    pdfButtons.forEach(btn => {
      if (!btn.dataset.copyHandler) {
        btn.dataset.copyHandler = "true";
        btn.title = "PDF-Link in Zwischenablage kopieren";

        btn.addEventListener("click", function (e) {
          e.preventDefault();

          let url = window.location.href;
          if (!url.includes("export=pdf")) {
            url += (url.includes("?") ? "&" : "?") + "export=pdf";
          }

          navigator.clipboard.writeText(url)
            .then(() => ew.alert("✅ PDF-Link wurde kopiert:\n" + url))
            .catch(err => ew.alert("❌ Fehler beim Kopieren: " + err));
        });
      }
    });
  }

  // Direkt prüfen + auf DOM-Änderungen reagieren
  attachSidebarCopyHandler();
  const obs = new MutationObserver(attachSidebarCopyHandler);
  obs.observe(document.body, { childList: true, subtree: true });
});
</script>


<?php
header("Expires: ".gmdate("D, d M Y H:i:s")." GMT");
header("Last-Modified: ".gmdate("D, d M Y H:i:s")." GMT");
header("Cache-Control: no-store, no-cache, must-revalidate");
header("Pragma: no-cache");
header("Cache-Control: post-check=0, pre-check=0", false);
?>

]]></CustomScript>
