  <CustomScript ScriptType="Template" ScriptCodeType="Table" ScriptName="CustomTemplate" ScriptCtrlID="view" ScriptL1Key="players"><![CDATA[<?php
// JSON auslesen aus charinfo-Feld
$json = json_decode($Page->charinfo->CurrentValue ?? '', true);

$firstname = $json["firstname"] ?? "";
$lastname = $json["lastname"] ?? "";
$birthdate = $json["birthdate"] ?? "";
$nationality = ucfirst($json["nationality"] ?? "");
$height = $json["height"] ?? "";
$phone = $json["phone"] ?? "";
$gender = isset($json["gender"]) ? ($json["gender"] == 0 ? "Männlich" : "Weiblich") : "";
$cid = $json["cid"] ?? "";

// Alter berechnen
$age = "";
if (!empty($birthdate)) {
    $birth = \DateTime::createFromFormat('m/d/Y', $birthdate) ?: DateTime::createFromFormat('d/m/Y', $birthdate);
    if ($birth) {
        $today = new \DateTime();
        $age = $today->diff($birth)->y;
    }
}
?>

<div class="p-3 my-3 mx-auto"
     style="max-width:600px;
            background:linear-gradient(145deg,#1b1f25,#23272e);
            border-radius:10px;
            box-shadow:0 2px 6px rgba(0,0,0,0.4);
            color:#e0e0e0;">

  <div class="d-flex align-items-center mb-2">
    <div class="me-3 bg-secondary rounded-circle d-flex align-items-center justify-content-center"
         style="width:70px;height:70px;">
      <i class="fa fa-user fa-2x text-light"></i>
    </div>
    <div>
      <h4 class="mb-1 text-light fw-bold"><?= htmlentities($firstname . " " . $lastname) ?></h4>
      <?php if ($cid) { ?>
        <small class="text-muted">Char-ID: <?= htmlentities($cid) ?></small>
      <?php } ?>
    </div>
  </div>

  <hr style="border-color:#333;margin:0.5rem 0;">

  <?php if ($birthdate) { ?>
  <p class="mb-2">
    <i class="fa fa-birthday-cake text-warning me-2"></i>
    Geboren am: <strong><?= htmlentities($birthdate) ?></strong>
    <?php if ($age !== "") { ?>
      <span class="text-muted">(Alter: <?= htmlentities($age) ?>)</span>
    <?php } ?>
  </p>
  <?php } ?>

  <?php if ($gender) { ?>
  <p class="mb-2">
    <i class="fa fa-venus-mars text-pink me-2"></i>
    Geschlecht: <strong><?= htmlentities($gender) ?></strong>
  </p>
  <?php } ?>

  <?php if ($nationality) { ?>
  <p class="mb-2">
    <i class="fa fa-flag text-success me-2"></i>
