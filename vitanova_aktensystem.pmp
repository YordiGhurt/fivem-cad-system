  </p>
  <?php } ?>

  <div class="text-end mt-3">
    <small class="text-muted">VitaNova Visasystem</small>
  </div>
</div>
]]></CustomScript>
  <CustomScript ScriptType="Server" ScriptCodeType="Table" ScriptName="Row_Inserting" ScriptL1Key="LSPD_Strafakten"><![CDATA[// Row Inserting event
function Row_Inserting($rsold, &$rsnew) {
	// Enter your code here
	// To cancel, set return value to FALSE
	$currentDate = date("d.m.Y H:i:s");
	$newnotiz = "Strafakte von " . CurrentUserName() . " am " . $currentDate . " angelegt.<hr />";
	$rsnew["Notiz"] = $newnotiz;
	//Status
	$rsnew["Status"] = "PD Bearbeitung";
	$rsnew["Agent"] = CurrentUserName();
	//Vorstrafe
	//$Vorstrafe = $rsnew["Vorstrafe"];
